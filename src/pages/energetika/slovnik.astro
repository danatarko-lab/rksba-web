    id: "zaruka-povodu",
    term: "Záruka pôvodu",
    abbr: "GO / EAC",
    def: "Certifikát (1 na MWh), ktorý preukazuje pôvod elektriny z OZE a dá sa previesť na iného účastníka; podklad pre firemné ESG vykazovanie.",
    why: "Nástroj, ktorým firma preukazuje zelený pôvod energie (Scope 2).",
    related: ["zelene-certifikaty", "re100", "granularne-hodinove-certifikaty", "scope-1-2-3-cbam"],
  },
  {
    id: "zdielanie-elektriny",
    term: "Zdieľanie elektriny",
    abbr: "skupina zdieľania",
    def: "Model, keď sa vyrobená elektrina cez verejnú sieť pripíše iným odberným miestam v skupine, ak sa spotrebuje v rovnakom časovom okne.",
    related: ["energeticka-komunita-spolocenstvo", "alokacny-kluc", "aktivny-zakaznik-aktivny-odberatel", "settlement"],
  },
  {
    id: "zelene-certifikaty",
    term: "Zelené certifikáty",
    abbr: "Green certificates",
    def: "Doklad, ktorý potvrdzuje pôvod elektriny z obnoviteľných zdrojov; dá sa s ním obchodovať.",
    related: ["zaruka-povodu", "re100", "adicionalita"],
  },
  {
    id: "zeleny-dlhopis",
    term: "Zelený dlhopis",
    abbr: "Green bond / EuGB",
    def: "Dlhopis, ktorého výnos financuje environmentálne udržateľné aktíva; európsky štandard sa viaže na EÚ taxonómiu.",
    related: ["eu-taxonomia", "sfdr", "dotacie-podpora-zeleny-uver"],
  },
  {
    id: "zero-trust-architektura",
    term: "Zero-trust architektúra",
    def: "Bezpečnostný prístup, kde sa žiadnemu spojeniu automaticky nedôveruje a všetko sa overuje.",
    related: ["nis2-cyber-resilience-act", "backdoor", "cloud-based-riesenie"],
  },
  {
    id: "zevo",
    term: "ZEVO",
    abbr: "zariadenie na energetické využitie odpadu",
    def: "Spaľovňa odpadu, ktorá z odpadu vyrába elektrinu a teplo; môže vstupovať na trh podporných služieb.",
    related: ["kogeneracia", "podporne-sluzby"],
  },
  {
    id: "zlozka-na-podporu-elektriny",
    term: "Zložka na podporu elektriny",
    def: "Regulovaná platba v cene elektriny, ktorá je určená na financovanie podpory obnoviteľných zdrojov.",
    related: ["tps", "cena-za-systemove-sluzby", "doplatok"],
  },
  {
    id: "zmluva-o-pripojeni-vs-zmluva-o-pristupe",
    term: "Zmluva o pripojení vs zmluva o prístupe",
    def: "Zmluva o pripojení rieši fyzické pripojenie zariadenia do sústavy; zmluva o prístupe zabezpečuje prepravu dohodnutého množstva elektriny za regulovanú cenu.",
    why: "Dva odlišné dokumenty s odlišnými poplatkami; časté nedorozumenie pri FVE a batérii.",
    related: ["g-komponent", "rezervovana-kapacita", "grid-access-pripojitelnost-mapy-pripojitelnosti"],
  },
  {
    id: "zony-zrychleneho-povolovania",
    term: "Zóny zrýchleného povoľovania",
    abbr: "go-to",
    def: "Územia vymedzené na zrýchlené povoľovanie obnoviteľných zdrojov energie.",
    related: ["red-iii", "nadradeny-verejny-zaujem", "nimby-efekt"],
  },
  {
    id: "zostatkova-hodnota",
    term: "Zostatková hodnota",
    abbr: "Residual value",
    def: "Odhadovaná hodnota zariadenia alebo projektu na konci sledovaného obdobia; vstupuje do NPV a návratnosti.",
    related: ["npv", "bol-eol", "business-case"],
  },
  {
    id: "zuctovatel-odchylok",
    term: "Zúčtovateľ odchýlok",
    abbr: "Imbalance settlement operator",
    def: "Osoba, ktorá zabezpečuje zúčtovanie rozdielov medzi zmluvnými a skutočnými dodávkami alebo odbermi.",
    related: ["odchylka-zuctovanie-odchylok", "subjekt-zuctovania"],
  },
];

const sorted = [...terms].sort((a, b) => a.term.localeCompare(b.term, 'sk'));
const byId = Object.fromEntries(terms.map((t) => [t.id, t]));

const letterAnchor = {};
for (const t of sorted) {
  const letter = t.term.charAt(0).toUpperCase();
  if (!letterAnchor[letter]) letterAnchor[letter] = t.id;
}
const letters = Object.keys(letterAnchor).sort((a, b) => a.localeCompare(b, 'sk'));

const termSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'Slovník energetických pojmov',
  hasDefinedTerm: terms.map((t) => ({
    '@type': 'DefinedTerm',
    name: t.term,
    description: t.def,
  })),
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/energetika">← Energetika</a></p>

    <p class="text-sm font-medium uppercase tracking-wider text-primary mb-3">Energetické riešenia pre firmy a budovy</p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Slovník energetických pojmov</h1>
    <p class="text-lg text-muted mb-8 max-w-3xl">
      Jednoduché vysvetlenia odborných a cudzích výrazov, ktoré sa objavujú v energetike a v našich článkoch. Slovník
      postupne dopĺňame.
    </p>

    <nav aria-label="Skočiť na písmeno" class="flex flex-wrap gap-2 pb-8 mb-10 border-b border-gray-200">
      {
        letters.map((letter) => (
          <a
            href={`#${letterAnchor[letter]}`}
            class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-gray-200 font-medium text-primary hover:bg-primary/5"
          >
            {letter}
          </a>
        ))
      }
    </nav>

    <div class="space-y-4">
      {
        sorted.map((t) => (
          <div id={t.id} class="scroll-mt-24 rounded-xl border border-gray-200 p-5">
            <p class="font-bold text-lg">
              {t.term}
              {t.abbr && <span class="font-normal text-muted"> ({t.abbr})</span>}
            </p>
            <p class="text-muted mt-2">{t.def}</p>
            {t.why && (
              <p class="text-muted mt-3">
                <span class="font-semibold text-gray-800">Prečo je to dôležité:</span> {t.why}
              </p>
            )}
            {t.related && t.related.length > 0 && (
              <p class="text-sm text-muted mt-3">
                <span class="font-semibold text-gray-800">Súvisiace pojmy:</span>{' '}
                {t.related
                  .map((rid) => byId[rid])
                  .filter(Boolean)
                  .map((r, i) => (
                    <>
                      {i > 0 && ', '}
                      <a class="text-primary hover:underline" href={`#${r.id}`}>
                        {r.term}
                      </a>
                    </>
                  ))}
              </p>
            )}
          </div>
        ))
      }
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(termSchema)} />
</Layout>
