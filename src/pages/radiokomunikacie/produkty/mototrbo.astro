---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroProdukt from '~/assets/images/radiokomunikacie/radio-07.webp';

const metadata = {
  title: 'MOTOTRBO: produktová línia Motorola | RKS',
  description:
    'MOTOTRBO je produktová línia digitálnych rádiostaníc a systémov Motorola, ktorú RKS dodáva, konfiguruje a servisuje. Produktový katalóg a digitálny systém MOTOTRBO.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/radiokomunikacie">← Rádiokomunikácie</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">MOTOTRBO</h1>

    <div class="grid items-center gap-8 lg:gap-10 lg:grid-cols-5 mb-12">
      <p class="text-lg text-muted lg:col-span-3">
        MOTOTRBO je produktová línia digitálnych rádiostaníc a systémov Motorola, ktorú RKS dodáva, konfiguruje a
        servisuje. Konkrétne zariadenia a modely nájdete v produktovom katalógu; ako systém pre vašu organizáciu ho
        navrhujeme v rámci našej služby.
      </p>
      <div class="lg:col-span-2 aspect-[4/3] overflow-hidden rounded-2xl shadow-sm">
        <Image
          src={heroProdukt}
          alt="Rádiostanice Motorola MOTOTRBO v nabíjacej stanici"
          widths={[400, 600, 768]}
          sizes="(max-width: 1023px) 100vw, 40vw"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <a
        href="https://mototrbo.sk"
        target="_blank"
        rel="noopener noreferrer"
        class="group block rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
      >
        <h2 class="text-lg font-medium mb-1 inline-flex items-center gap-1">
          Produktový katalóg MOTOTRBO <span aria-hidden="true">↗</span>
        </h2>
        <p class="text-sm text-muted mb-4">Konkrétne zariadenia a modely (vlastný katalóg RKS na mototrbo.sk).</p>
        <span class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
          Otvoriť katalóg <span aria-hidden="true">↗</span>
        </span>
      </a>

      <a
        href="/radiokomunikacie/sluzby/digitalny-system-mototrbo"
        class="group block rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
      >
        <h2 class="text-lg font-medium mb-1">Digitálny systém MOTOTRBO ako služba</h2>
        <p class="text-sm text-muted mb-4">
          Návrh, dodávka, konfigurácia a servis systému MOTOTRBO pre vašu organizáciu.
        </p>
        <span class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
          Otvoriť <span aria-hidden="true">→</span>
        </span>
      </a>
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Zaujíma vás riešenie MOTOTRBO?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Pripravíme návrh dodávky a konfigurácie pre vašu organizáciu.</p>
      <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary inline-flex"
        >Dohodnúť nezáväznú konzultáciu</a
      >
    </div>
  </section>
</Layout>
