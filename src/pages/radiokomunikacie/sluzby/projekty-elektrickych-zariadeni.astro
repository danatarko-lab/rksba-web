---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroProjektovanie from '~/assets/images/radiokomunikacie/city-11.webp';

const metadata = {
  title: 'Projektovanie elektrických zariadení | RKS',
  description:
    'Technická a konštrukčná dokumentácia elektrických zariadení na kľúč, NN rozvody, EPS, evakuačný rozhlas, EZS/PSN, štruktúrovaná kabeláž, trafostanice VN/NN. V súlade s STN EN a UNIKA.',
};

const faqs = [
  {
    q: 'V akom rozsahu spracovávate dokumentáciu?',
    a: 'Kompletnú technickú a konštrukčnú dokumentáciu v úrovni Lay Out aj na kľúč, od NN rozvodov cez slaboprúdové systémy až po trafostanice VN/NN bez obmedzenia výkonu.',
  },
  {
    q: 'Máte oprávnenia na požiarne a zabezpečovacie systémy?',
    a: 'Áno. EPS v súlade s STN EN 54-1 (oprávnenie ESSER, ARITECH), požiarny evakuačný rozhlas podľa STN EN 54-16 a 54-24, EZS/PSN s oprávnením od výrobcu PARADOX (Canada).',
  },
  {
    q: 'Riešite aj špecifické prostredia?',
    a: 'Áno. Pri návrhu do prostredí ako atómové elektrárne či dispečerské pracoviská kladieme dôraz na koordináciu s prevádzkou a na EMC zariadení.',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/radiokomunikacie">← Rádiokomunikácie</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Projektovanie elektrických zariadení</h1>

    <div class="grid items-center gap-8 lg:gap-10 lg:grid-cols-5 mb-12">
      <p class="text-lg text-muted lg:col-span-3">
        Každá úspešná realizácia začína kvalitným projektom, chyba v dokumentácii sa na stavbe predraží. Pripravíme
        technickú a konštrukčnú dokumentáciu elektrických zariadení v úrovni Lay Out aj na kľúč, s dôrazom na
        bezpečnosť, správne dimenzovanie a elektromagnetickú kompatibilitu (EMC).
      </p>
      <div class="lg:col-span-2 aspect-[4/3] overflow-hidden rounded-2xl shadow-sm">
        <Image
          src={heroProjektovanie}
          alt="Elektrické zariadenia a rozvodňa, projektovanie elektrických zariadení"
          widths={[400, 600, 768]}
          sizes="(max-width: 1023px) 100vw, 40vw"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="prose prose-lg max-w-none">
      <h2>Na čo pri návrhu dbáme</h2>
      <p>
        Okrem dimenzovania s ohľadom na nárast energetickej bilancie navrhujeme ochranné a bezpečnostné prvky z pohľadu
        úrazovosti elektrickým prúdom aj ochrany pred bleskovými prúdmi a prevádzkovými prepätiami. Dôležitú úlohu
        zohráva elektromagnetická kompatibilita (EMC). Pri slaboprúdových rozvodoch kladieme dôraz na ergonómiu, komfort
        a kvalitu prenosu informácií so zreteľom na ekonomiku riešenia.
      </p>

      <h2>Rozsah dokumentácie</h2>
      <ul>
        <li>elektrické rozvody NN: vnútorné priemyselné elektroinštalácie,</li>
        <li>vonkajšie káblové a sekundárne vzdušné rozvody NN,</li>
        <li>
          <strong>elektronická požiarna signalizácia (EPS)</strong> v súlade s STN EN 54-1 a súvisiacimi, oprávnenie od výrobcov
          <strong>ESSER a ARITECH</strong>,
        </li>
        <li><strong>požiarny evakuačný rozhlas (PR)</strong> v súlade s STN EN 54-16 a STN EN 54-24,</li>
        <li>
          <strong>elektronický zabezpečovací systém (EZS) / poplachový systém narušenia (PSN)</strong>: oprávnenie od
          výrobcu
          <strong>PARADOX (Canada)</strong>,
        </li>
        <li><strong>štruktúrovaná kabeláž (STK)</strong> v súlade s STN EN 50173-1/2,</li>
        <li>transformačné stanice VN/NN bez obmedzenia výkonu,</li>
        <li>odborné prehliadky a skúšky vyhradených technických zariadení elektrických vrátane bleskozvodov.</li>
      </ul>

      <h2>Stupne projektovej dokumentácie</h2>
      <p>
        V súlade s <strong>UNIKA</strong> vo všetkých stupňoch: PD pre územné rozhodnutie, PD pre stavebné povolenie, realizačná
        PD, dokumentácia skutkového zhotovenia.
      </p>
    </div>

    <h2 class="text-2xl font-semibold tracking-tight mt-14 mb-6">Časté otázky</h2>
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 p-5">
            <summary class="cursor-pointer list-none font-medium marker:hidden flex justify-between items-center gap-4">
              {faq.q}
              <span class="text-primary transition group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="text-muted mt-3">{faq.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Pripravujete projekt elektrického zariadenia?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Spracujeme projektovú dokumentáciu v potrebnom stupni a rozsahu.</p>
      <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary inline-flex"
        >Dohodnúť nezáväznú konzultáciu</a
      >
    </div>
  </section>
</Layout>
