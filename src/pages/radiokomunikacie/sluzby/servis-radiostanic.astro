---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroServis from '~/assets/images/radiokomunikacie/service-05.webp';

const metadata = {
  title: 'Servis profesionálnych rádiostaníc Motorola, Midland, Vertex, Icom — RKS',
  description:
    'Záručný aj pozáručný servis rádiostaníc Motorola, Midland, Vertex a Icom. Diagnostika, opravy, programovanie, montáž vozidlových zostáv aj servis sirén a rozhlasov.',
};

const faqs = [
  {
    q: 'Rádiostanice ktorých značiek servisujete?',
    a: 'Motorola, Midland, Vertex a Icom — vrátane digitálnych systémov MOTOTRBO.',
  },
  {
    q: 'Musím mať na servis zmluvu?',
    a: 'Nie. Servis poskytujeme jednorazovo na objednávku, alebo na celoročnú servisnú zmluvu.',
  },
  {
    q: 'Servisujete aj sirény a rozhlasové ústredne?',
    a: 'Áno. Elektronické sirény Sircom, PSE, Ergatec a EVS a rozhlasové ústredne TOA.',
  },
  {
    q: 'Sú ceny opráv vopred známe?',
    a: 'Áno. Poskytujeme garantované ceny opráv, príslušenstva aj servisných prác.',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/radiokomunikacie">← Rádiokomunikácie</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Servis a oprava rádiostaníc</h1>

    <div class="grid items-center gap-8 lg:gap-10 lg:grid-cols-5 mb-12">
      <p class="text-lg text-muted lg:col-span-3">
        Keď rádiostanica vypadne, stojí komunikácia — a často aj prevádzka. Poskytujeme záručný aj pozáručný servis
        profesionálnych rádiostaníc, ktorý zabezpečujú servisné skupiny s pravidelne školenými technikmi a skúsenosťami
        z veľkých inštalácií. Servis riešime jednorazovo aj na celoročnú zmluvu, s garantovanými cenami opráv vopred.
      </p>
      <div class="lg:col-span-2 aspect-[4/3] overflow-hidden rounded-2xl shadow-sm">
        <Image
          src={heroServis}
          alt="Servis a oprava profesionálnej rádiostanice RKS"
          widths={[400, 600, 768]}
          sizes="(max-width: 1023px) 100vw, 40vw"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <a
      href="/katalog-produktov"
      class="block mb-12 rounded-2xl border border-gray-200 p-6 hover:shadow-md hover:border-primary/40 transition"
    >
      <p class="font-semibold mb-1">Katalóg produktov</p>
      <p class="text-muted">Parametre, dokumentácia a servisné informácie.</p>
    </a>

    <div class="prose prose-lg max-w-none">
      <h2>Servisované značky</h2>
      <p>
        Kompletný servis profesionálnych rádiostaníc značiek <strong>Motorola, Midland, Vertex a Icom</strong> — vrátane
        digitálnych systémov Motorola MOTOTRBO.
      </p>

      <h2>Čo servis zahŕňa</h2>
      <ul>
        <li>bežná údržba a inšpekčné prehliadky,</li>
        <li>servisné a mechanické opravy vrátane expresných,</li>
        <li>diagnostika a softvérové nastavenie parametrov,</li>
        <li>programovanie rádiostaníc a konfigurácia siete,</li>
        <li>montáž a demontáž vozidlových, základňových a retranslačných staníc,</li>
        <li>predaj príslušenstva a doplnkov vrátane montáže.</li>
      </ul>

      <h2>Servis sirén a rozhlasov</h2>
      <p>
        Okrem rádiostaníc zabezpečujeme montáž a servis elektronických sirén značiek
        <strong>Sircom, PSE, Ergatec a EVS</strong> a rozhlasových ústrední značky <strong>TOA</strong> — údržbu,
        prehliadky, opravy, diagnostiku aj softvérové nastavenie.
      </p>

      <h2>Ako servis funguje</h2>
      <p>
        Servis poskytujeme jednorazovo na základe objednávky, alebo na základe zmluvy o celoročnom servise. Pri všetkých
        opravách platia garantované ceny opráv, príslušenstva aj servisných prác — viete vopred, na čom ste.
      </p>

      <h2>Výhody servisnej zmluvy</h2>
      <ul>
        <li>pravidelné kontroly a preventívna údržba,</li>
        <li>prednostné a kratšie servisné termíny,</li>
        <li>nižšie riziko neplánovaných výpadkov.</li>
      </ul>
    </div>

    <h2 class="text-2xl font-semibold tracking-tight mt-14 mb-6">Časté otázky</h2>
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 p-5">
            <summary class="cursor-pointer list-none font-medium marker:hidden flex justify-between items-center gap-4">
              {faq.q}
              <span class="text-primary transition group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="text-muted mt-3">{faq.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Potrebujete opraviť alebo zaservisovať techniku?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Dohodneme jednorazový servis alebo celoročnú zmluvu.</p>
      <a href="/lp/konzultacia.html?utm_source=web&amp;utm_campaign=web" class="btn-primary inline-flex">Dohodnúť nezáväznú konzultáciu</a>
    </div>
  </section>
</Layout>
