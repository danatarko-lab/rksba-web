---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroDigitalizaciaSiete from '~/assets/images/radiokomunikacie/ion-7.webp';

const metadata = {
  title: 'Digitalizácia rádiových sietí — prechod na DMR — RKS',
  description:
    'Modernizujeme analógové rádiové siete na digitálne DMR riešenia. Vyššia spoľahlivosť, šifrovanie, GPS a nové funkcie s dôrazom na kontinuitu prevádzky a zachovanie existujúcej infraštruktúry.',
};

const faqs = [
  {
    q: 'Musíme meniť všetky rádiostanice?',
    a: 'Nie. Mnohé zariadenia je možné zachovať.',
  },
  {
    q: 'Dá sa digitalizovať po etapách?',
    a: 'Áno. Väčšina projektov prebieha postupnou migráciou.',
  },
  {
    q: 'Aké organizácie najčastejšie digitalizujú siete?',
    a: 'Výroba, energetika, logistika, mestá, priemyselné podniky a kritická infraštruktúra.',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/radiokomunikacie">← Rádiokomunikácie</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Digitalizácia rádiových sietí</h1>

    <div class="grid items-center gap-8 lg:gap-10 lg:grid-cols-5 mb-12">
      <p class="text-lg text-muted lg:col-span-3">
        Modernizácia rádiovej siete prináša vyššiu spoľahlivosť, lepšiu kvalitu komunikácie a nové možnosti riadenia —
        bez toho, aby ste museli vymeniť všetko naraz. Digitalizáciu navrhujeme tak, aby sme zachovali čo najväčšiu časť
        existujúcej infraštruktúry a minimalizovali odstávky.
      </p>
      <div class="lg:col-span-2 aspect-[4/3] overflow-hidden rounded-2xl shadow-sm">
        <Image
          src={heroDigitalizaciaSiete}
          alt="Moderná digitálna rádiostanica Motorola s dotykovým displejom"
          widths={[400, 600, 768]}
          sizes="(max-width: 1023px) 100vw, 40vw"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="prose prose-lg max-w-none">
      <h2>Výhody digitálnej siete</h2>
      <ul>
        <li>kvalitnejší prenos hlasu a vyššia kapacita siete,</li>
        <li>GPS lokalizácia,</li>
        <li>šifrovanie komunikácie,</li>
        <li>dispečerské aplikácie,</li>
        <li>jednoduchšia správa siete,</li>
        <li>nižšie prevádzkové náklady,</li>
        <li>pripravenosť na ďalší rozvoj.</li>
      </ul>

      <h2>Ako prebieha modernizácia</h2>
      <ol>
        <li>Audit existujúcej siete</li>
        <li>Návrh riešenia</li>
        <li>Overenie kompatibility zariadení</li>
        <li>Postupná migrácia</li>
        <li>Testovanie</li>
        <li>Zaškolenie používateľov</li>
        <li>Servisná podpora</li>
      </ol>

      <h2>Prečo digitalizovať s RKS</h2>
      <p>
        Modernizáciu realizujeme s dôrazom na kontinuitu prevádzky. Naším cieľom nie je výmena všetkého vybavenia, ale
        technicky aj ekonomicky optimálne riešenie — väčšina projektov prebieha postupnou migráciou.
      </p>
    </div>

    <h2 class="text-2xl font-semibold tracking-tight mt-14 mb-6">Časté otázky</h2>
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 p-5">
            <summary class="cursor-pointer list-none font-medium marker:hidden flex justify-between items-center gap-4">
              {faq.q}
              <span class="text-primary transition group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="text-muted mt-3">{faq.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Premýšľate nad modernizáciou rádiovej siete?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Pripravíme plán digitalizácie prispôsobený vašej prevádzke.</p>
      <a href="/kontakt" class="btn-primary inline-flex">Dohodnúť nezáväznú konzultáciu</a>
    </div>
  </section>
</Layout>
