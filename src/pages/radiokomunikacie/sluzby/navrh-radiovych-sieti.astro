---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroNavrhSieti from '~/assets/images/radiokomunikacie/dispatcher-02a.webp';

const metadata = {
  title: 'Návrh a projektovanie rádiových sietí | RKS',
  description:
    'Navrhujeme profesionálne rádiové siete pre priemysel, energetiku, logistiku aj verejnú správu. Analýza, simulácia pokrytia, frekvenčný plán, projektová dokumentácia v súlade s UNIKA aj realizácia.',
};

const faqs = [
  {
    q: 'Kedy je vhodné projektovať novú rádiovú sieť?',
    a: 'Pri budovaní novej prevádzky, rozširovaní existujúcej siete alebo modernizácii analógových systémov na digitálne.',
  },
  {
    q: 'Navrhujete aj pokrytie signálom?',
    a: 'Áno. Súčasťou návrhu je analýza pokrytia, simulácie šírenia signálu aj merania v teréne.',
  },
  {
    q: 'Zabezpečujete aj realizáciu a legislatívu?',
    a: 'Áno. Od projektu cez podklady na pridelenie frekvencie až po uvedenie siete do prevádzky.',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/radiokomunikacie">← Rádiokomunikácie</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
      Návrh a projektovanie profesionálnych rádiových sietí
    </h1>

    <div class="grid items-center gap-8 lg:gap-10 lg:grid-cols-5 mb-12">
      <p class="text-lg text-muted lg:col-span-3">
        Spoľahlivá rádiová sieť nevznikne náhodou, stojí na presnom návrhu pokrytia, frekvenčnom pláne a znalosti
        terénu. RKS zabezpečuje kompletný návrh a projektovanie rádiových sietí od úvodnej analýzy cez simuláciu šírenia
        signálu až po realizačnú dokumentáciu a podporu pri uvedení do prevádzky. Každé riešenie navrhujeme individuálne
        podľa veľkosti objektu, požadovaného pokrytia, typu prevádzky a plánovaného rozvoja.
      </p>
      <div class="lg:col-span-2 aspect-[4/3] overflow-hidden rounded-2xl shadow-sm">
        <Image
          src={heroNavrhSieti}
          alt="Dispečerské pracovisko s mapou pokrytia rádiovej siete"
          widths={[400, 600, 768]}
          sizes="(max-width: 1023px) 100vw, 40vw"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="prose prose-lg max-w-none">
      <h2>Čo zahŕňa návrh rádiovej siete</h2>
      <p>
        Návrhy spracovávame na základe vašich požiadaviek, našich skúseností a konzultácií s Úradom pre reguláciu
        elektronických komunikácií a poštových služieb (regulačný úrad, RÚ). Pri spracovaní využívame:
      </p>
      <ul>
        <li>analýzu požiadaviek a návrh architektúry siete,</li>
        <li>návrh pokrytia rádiovým signálom a jeho optimalizáciu,</li>
        <li>geografické merania pomocou GPS a digitálny model terénu,</li>
        <li>simuláciu šírenia rádiového signálu,</li>
        <li>výpočty intermodulačných produktov,</li>
        <li>návrh frekvenčného plánu a retranslačných staníc,</li>
        <li>návrh anténnych systémov,</li>
        <li>spracovanie podkladov na pridelenie frekvencie regulačným úradom.</li>
      </ul>

      <h2>Projektová dokumentácia</h2>
      <p>
        Pre siete väčšieho rozsahu zabezpečíme kompletnú dokumentáciu v súlade so sadzobníkom <strong>UNIKA</strong>:
      </p>
      <ul>
        <li>projektová dokumentácia pre územné rozhodnutie,</li>
        <li>projektová dokumentácia pre stavebné povolenie,</li>
        <li>realizačná projektová dokumentácia,</li>
        <li>dokumentácia skutočného vyhotovenia,</li>
        <li>vyjadrenia dotknutých osôb a organizácií, podpora pri kolaudácii.</li>
      </ul>

      <h2>Výhody spolupráce s RKS</h2>
      <p>
        Dlhoročná spolupráca s regulačným úradom, individuálny návrh podľa prevádzky, znalosť legislatívy, kompletné
        riešenie na kľúč a servis po realizácii.
      </p>
    </div>

    <h2 class="text-2xl font-semibold tracking-tight mt-14 mb-6">Časté otázky</h2>
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 p-5">
            <summary class="cursor-pointer list-none font-medium marker:hidden flex justify-between items-center gap-4">
              {faq.q}
              <span class="text-primary transition group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="text-muted mt-3">{faq.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Potrebujete navrhnúť profesionálnu rádiovú sieť?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">
        Pripravíme riešenie presne podľa vašej prevádzky a možností regulačného úradu.
      </p>
      <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary inline-flex"
        >Dohodnúť nezáväznú konzultáciu</a
      >
    </div>
  </section>
</Layout>
