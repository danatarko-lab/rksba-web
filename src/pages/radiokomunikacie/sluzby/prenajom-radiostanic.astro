---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroPrenajom from '~/assets/images/radiokomunikacie/hospitality-21.webp';

const metadata = {
  title: 'Prenájom profesionálnych rádiostaníc Motorola | RKS',
  description:
    'Krátkodobý aj dlhodobý prenájom profesionálnych rádiostaníc Motorola pre firmy a podujatia. Okamžitá prevádzka, nízke vstupné náklady, kompletný servis. Cenník na vyžiadanie.',
};

const faqs = [
  {
    q: 'Potrebujem na prenajaté rádiostanice povolenie?',
    a: 'Nie. RKS je držiteľom povolenia od Úradu pre reguláciu elektronických komunikácií a poštových služieb; stanice sa prevádzkujú na základe zmluvy s RKS.',
  },
  {
    q: 'Čo ak sa rádiostanica počas prenájmu pokazí?',
    a: 'V prípade poruchy, ktorú nemožno opraviť na počkanie, poskytneme náhradné zariadenie.',
  },
  {
    q: 'Dá sa zapožičať aj príslušenstvo?',
    a: 'Áno, rezervné akumulátory, nabíjačky, náhlavné súpravy či mikrofóny.',
  },
  {
    q: 'Aká je cena prenájmu?',
    a: 'Závisí od typu zariadenia, počtu kusov a dĺžky prenájmu. Cenník pošleme na vyžiadanie.',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/radiokomunikacie">← Rádiokomunikácie</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Prenájom rádiostaníc</h1>

    <div class="grid items-center gap-8 lg:gap-10 lg:grid-cols-5 mb-12">
      <p class="text-lg text-muted lg:col-span-3">
        Keď potrebujete komunikáciu len na obmedzený čas, kúpa techniky nedáva zmysel. Prenájom rádiostaníc vám dá
        profesionálne zariadenia okamžite, bez vstupnej investície a bez vlastného povolenia, RKS je držiteľom povolenia
        od Úradu pre reguláciu elektronických komunikácií a poštových služieb. Prenajaté stanice sa prevádzkujú na
        základe zmluvy s RKS.
      </p>
      <div class="lg:col-span-2 aspect-[4/3] overflow-hidden rounded-2xl shadow-sm">
        <Image
          src={heroPrenajom}
          alt="Profesionálna rádiostanica na prenájom"
          widths={[400, 600, 768]}
          sizes="(max-width: 1023px) 100vw, 40vw"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="prose prose-lg max-w-none">
      <h2>Kedy využiť prenájom</h2>
      <p>
        Pri jednorazových podujatiach aj prevádzkových situáciách, keď treba pokryť prechodný nedostatok rádiostaníc,
        dočasne zabezpečiť komunikáciu pri montážach a inštaláciách technológií, alebo pri kultúrnych, spoločenských a
        športových akciách.
      </p>

      <h2>Výhody prenájmu</h2>
      <ul>
        <li>prenajímateľ nepotrebuje vlastné povolenie na používanie rádiostaníc,</li>
        <li>okamžitá dostupnosť a jednoduchá obsluha,</li>
        <li>nízke vstupné náklady,</li>
        <li>spoľahlivosť profesionálnych rádiostaníc Motorola,</li>
        <li>možnosť zapožičania príslušenstva,</li>
        <li>kompletný servis vrátane náhradného zariadenia pri poruche.</li>
      </ul>

      <h2>Typické využitie</h2>
      <p>
        Stavebné projekty a montáže technológií, výrobné odstávky, logistické centrá, kultúrne, športové a spoločenské
        podujatia, bezpečnostné akcie.
      </p>

      <h2>Cenník na vyžiadanie</h2>
      <p>
        Cena prenájmu závisí od typu zariadenia (prenosná či vozidlová rádiostanica), počtu kusov, dĺžky prenájmu a
        zapožičaného príslušenstva. Aktuálny cenník nájmu vám radi pošleme na vyžiadanie.
      </p>
    </div>

    <h2 class="text-2xl font-semibold tracking-tight mt-14 mb-6">Časté otázky</h2>
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 p-5">
            <summary class="cursor-pointer list-none font-medium marker:hidden flex justify-between items-center gap-4">
              {faq.q}
              <span class="text-primary transition group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="text-muted mt-3">{faq.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Potrebujete rádiostanice na prenájom?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">
        Napíšte nám počet kusov a termín, pošleme cenník a pripravíme stanice na okamžité nasadenie.
      </p>
      <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary inline-flex"
        >Vyžiadať cenník a konzultáciu</a
      >
    </div>
  </section>
</Layout>
