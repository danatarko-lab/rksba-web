---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroElektro from '~/assets/images/radiokomunikacie/stavba-r5-3.webp';

const metadata = {
  title: 'Elektroinštalačné práce do 1000 V | RKS',
  description:
    'Silnoprúdové, dátové a slaboprúdové rozvody, bleskozvody, prepäťová ochrana, rozvody EPS, kamerových a rozhlasových systémov. Realizácia na kľúč vrátane prepojenia s rádiovými systémami.',
};

const faqs = [
  {
    q: 'Aké elektroinštalačné práce vykonávate?',
    a: 'Práce do 1000 V — silnoprúdové, dátové aj slaboprúdové rozvody, opravy a rekonštrukcie inštalácií a rozvádzačov, montáž bleskozvodov a prepäťovej ochrany.',
  },
  {
    q: 'Robíte aj slaboprúdové a dátové rozvody?',
    a: 'Áno. Metalické aj optické rozvody, dátové a telefónne rozvody, rozvody pre kamerové systémy, evakuačné a domáce rozhlasy, EPS aj koaxiálne VF rozvody.',
  },
  {
    q: 'Prepojíte elektroinštaláciu s rádiovými a varovnými systémami?',
    a: 'Áno. Pri komplexných dodávkach dbáme na správne prepojenie všetkých systémov do jedného funkčného celku.',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/radiokomunikacie">← Rádiokomunikácie</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Elektroinštalačné práce</h1>

    <div class="grid items-center gap-8 lg:gap-10 lg:grid-cols-5 mb-12">
      <p class="text-lg text-muted lg:col-span-3">
        Elektrická inštalácia je súčasťou stavby od jej vzniku a jej prevedenie priamo ovplyvňuje bezpečnosť, komfort
        užívania aj celkovú kvalitu objektu. Realizujeme silnoprúdové aj slaboprúdové rozvody na kľúč — s prípravou na
        budúce rozšírenia a so správnym prepojením na rádiové a varovné systémy.
      </p>
      <div class="lg:col-span-2 aspect-[3/4] overflow-hidden rounded-2xl shadow-sm">
        <Image
          src={heroElektro}
          alt="Pracovník s rádiostanicou pri elektroinštalačných prácach na stavbe"
          widths={[400, 600, 768]}
          sizes="(max-width: 1023px) 100vw, 40vw"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="prose prose-lg max-w-none">
      <h2>Komplexná realizácia inštalácie</h2>
      <p>
        Inštalácia väčšiny objektov pozostáva z vnútorných silnoprúdových rozvodov, vnútorných dátových rozvodov a
        vonkajších rozvodov. Vhodnou koordináciou projektu dosiahneme optimálne rozloženie prípojných bodov, rozvodných
        skríň a rozvádzačov tak, aby boli rozvody pripravené aj na budúce rozšírenia.
      </p>

      <h2>Čo ponúkame</h2>
      <ul>
        <li>elektroinštalačné práce do 1000 V,</li>
        <li>identifikácia a opravy elektrickej inštalácie,</li>
        <li>rekonštrukcie elektroinštalácie a rozvádzačov,</li>
        <li>montáž bleskozvodov a prepäťová ochrana,</li>
        <li>slaboprúdové rozvody (metalické, optické),</li>
        <li>dátové a telefónne rozvody,</li>
        <li>rozvody pre ochranu objektov, kamerové systémy, evakuačné a domáce rozhlasy,</li>
        <li>rozvody EPS (elektrická požiarna signalizácia),</li>
        <li>analógové koaxiálne VF rozvody.</li>
      </ul>

      <h2>Súčasť funkčného celku</h2>
      <p>
        Pri komplexných dodávkach rádiových sietí a systémov VAR-VYR dbáme na správne prepojenie všetkých systémov do
        jedného funkčného celku spoločne s elektroinštaláciou. Výhodou je, že projektovanie, elektroinštalácia aj
        rádiové systémy sú pod jednou spoločnosťou.
      </p>
    </div>

    <h2 class="text-2xl font-semibold tracking-tight mt-14 mb-6">Časté otázky</h2>
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 p-5">
            <summary class="cursor-pointer list-none font-medium marker:hidden flex justify-between items-center gap-4">
              {faq.q}
              <span class="text-primary transition group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="text-muted mt-3">{faq.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Plánujete elektroinštaláciu alebo rekonštrukciu?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Zrealizujeme silnoprúdové aj slaboprúdové rozvody na kľúč.</p>
      <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary inline-flex"
        >Dohodnúť nezáväznú konzultáciu</a
      >
    </div>
  </section>
</Layout>
