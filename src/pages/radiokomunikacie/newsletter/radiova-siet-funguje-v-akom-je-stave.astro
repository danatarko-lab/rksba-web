---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import ceoPortret from '~/assets/images/rks-ceo-portret.webp';
import NewsletterCTA from '~/components/widgets/NewsletterCTA.astro';

const metadata = {
  title: 'Rádiová sieť funguje. Ale viete, v akom je stave? — RKS',
  description:
    'Pozdrav od riaditeľa, Newsletter č. 1. To, že komunikačný systém funguje dnes, ešte neznamená, že poznáte jeho skutočný stav.',
};

const post = {
  category: 'Newsletter',
  number: '#001',
  title: 'Rádiová sieť funguje. Ale viete, v akom je stave?',
  date: '2. 7. 2026',
  author: 'Vladimír Svatý',
  authorRole: 'CEO, RKS · v profesionálnej komunikácii od roku 1991',
};
---

<Layout metadata={metadata}>
  <!-- Hero — jemný navy banner (mockup, bez reálnej fotky) -->
  <div class="bg-gradient-to-br from-[#0b1b3a] via-[#13234d] to-primary text-white">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 py-14 md:py-20">
      <p class="text-xs font-semibold tracking-widest text-white/60 uppercase mb-3">Pozdrav od riaditeľa</p>
      <p class="text-xs font-semibold tracking-widest text-accent uppercase mb-5">
        Potvrďte príjem · {post.number}
      </p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight leading-tight">{post.title}</h1>
    </div>
  </div>

  <article class="mx-auto max-w-3xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-8">
      <a class="hover:underline" href="/radiokomunikacie/newsletter">← Newsletter</a>
    </p>

    <!-- Autor + dátum -->
    <div class="flex items-center justify-between flex-wrap gap-4 pb-8 mb-10 border-b border-gray-200">
      <div class="flex items-center gap-3">
        <Image
          src={ceoPortret}
          alt="Vladimír Svatý, CEO RKS"
          width={48}
          height={48}
          class="h-12 w-12 rounded-full object-cover"
        />
        <div>
          <p class="font-semibold">{post.author}</p>
          <p class="text-sm text-muted">{post.authorRole}</p>
        </div>
      </div>
      <p class="text-sm text-muted">{post.date}</p>
    </div>

    <div class="prose prose-lg max-w-none">
      <p>
        Pred časom som sedel na stretnutí vo firme, ktorá používala vlastnú rádiovú sieť viac ako 15 rokov.
      </p>
      <p>Na prvý pohľad bolo všetko v poriadku.</p>
      <p>
        Ľudia komunikovali.<br />
        Prevádzka fungovala.<br />
        Nikto sa nesťažoval.
      </p>
      <p>Potom padla jednoduchá otázka:</p>
      <blockquote>
        <p>„Koľko rádiostaníc dnes reálne používate?“</p>
      </blockquote>
      <p>V miestnosti nastalo ticho. Nie preto, že by niekto niečo zanedbal.</p>
      <p>
        Skôr preto, že rádiová sieť je vo väčšine organizácií podobná elektrine alebo rozvodom vody. Kým funguje,
        nikto ju nerieši.
      </p>

      <h2>Čo firmy o svojej komunikácii často nevedia</h2>
      <p>
        Po rokoch v odbore sa však opakovane stretávam s jednou vecou. Firmy presne vedia, koľko majú vozidiel,
        notebookov alebo mobilných telefónov. Pri komunikačnom systéme však býva prehľad často neúplný. Napríklad:
      </p>
      <ul>
        <li>nie je jasné, koľko zariadení sa reálne používa,</li>
        <li>batérie už nemajú pôvodnú kapacitu,</li>
        <li>areál sa za roky zmenil a s ním aj pokrytie,</li>
        <li>evidencia zariadení nie je aktuálna,</li>
        <li>zodpovednosť za systém sa postupne rozplynula medzi viacerých ľudí.</li>
      </ul>
    </div>

    <!-- Callout: Podstata veci -->
    <div class="my-10 rounded-2xl bg-[#0b1b3a] text-white p-8">
      <p class="text-xs font-semibold tracking-widest text-white/60 uppercase mb-3">Podstata veci</p>
      <p class="text-xl md:text-2xl font-semibold leading-snug">
        A práve preto veľmi často nie je najväčším problémom vek technológie samotný. Je ním
        <strong>nedostatok aktuálnych informácií o jej stave.</strong>
      </p>
    </div>

    <div class="prose prose-lg max-w-none">
      <h2>3 otázky z terénu</h2>
    </div>

    <div class="mt-6 space-y-5">
      <div class="rounded-xl border-l-4 border-primary bg-gray-50 p-5">
        <p class="font-semibold mb-2">Znamená staršia rádiová sieť automaticky problém?</p>
        <p class="text-muted">
          <strong class="text-default">Nie.</strong> Mnohé staršie systémy fungujú spoľahlivo aj po rokoch. Dôležité
          je, či stále zodpovedajú dnešnej prevádzke, priestoru a spôsobu práce.
        </p>
      </div>
      <div class="rounded-xl border-l-4 border-primary bg-gray-50 p-5">
        <p class="font-semibold mb-2">Čo býva najčastejšie slabé miesto?</p>
        <p class="text-muted">
          <strong class="text-default">Prekvapivo to často nie je samotná rádiostanica.</strong> Veľmi často sú to
          batérie, evidencia zariadení, pokrytie po zmenách v areáli alebo chýbajúci prehľad o tom, kto systém spravuje.
        </p>
      </div>
      <div class="rounded-xl border-l-4 border-primary bg-gray-50 p-5">
        <p class="font-semibold mb-2">Kedy firmy zistia, že majú problém?</p>
        <p class="text-muted">
          <strong class="text-default">Najčastejšie počas situácie, keď komunikáciu naozaj potrebujú.</strong> Pri
          poruche. Počas odstávky. Pri bezpečnostnom incidente. Práve vtedy sa ukáže, či sa informácia dostane k
          správnym ľuďom v správnom čase.
        </p>
      </div>
    </div>

    <!-- Callout: Jedna myšlienka na záver -->
    <div class="my-10 rounded-2xl border border-primary/20 bg-primary/5 p-8">
      <p class="text-xs font-semibold tracking-widest text-primary uppercase mb-3">Jedna myšlienka na záver</p>
      <p class="text-xl md:text-2xl font-semibold leading-snug mb-3">
        To, že komunikačný systém funguje dnes, ešte neznamená, že poznáte jeho skutočný stav.
      </p>
      <p class="text-muted">A práve ten rozdiel býva často dôležitejší než vek samotnej technológie.</p>
    </div>

    <!-- Autor — podpis -->
    <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row sm:items-start gap-5">
      <Image
        src={ceoPortret}
        alt="Vladimír Svatý, CEO RKS"
        width={112}
        height={112}
        class="h-24 w-24 sm:h-28 sm:w-28 rounded-2xl object-cover shrink-0"
      />
      <div>
        <p class="font-semibold">{post.author}</p>
        <p class="text-sm text-muted mb-4">CEO, RKS</p>
        <p class="italic text-muted">
          Už viac ako 30 rokov pomáham organizáciám navrhovať, budovať a rozvíjať profesionálne komunikačné systémy.
        </p>
      </div>
    </div>

    <p class="mt-8 text-sm text-muted">
      RKS — návrh, modernizácia a servis profesionálnych komunikačných systémov od roku 1991.
    </p>

    <!-- CTA -->
    <div class="mt-12 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Poznáte skutočný stav svojej rádiovej siete?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Ozvite sa nám — pomôžeme vám získať prehľad o stave vašej komunikácie.</p>
      <a href="/lp/konzultacia.html?utm_source=web&amp;utm_campaign=web" class="btn-primary inline-flex">Dohodnúť nezáväznú konzultáciu</a>
    </div>

    <!-- Súvisiace články — placeholdery -->
    <div class="mt-16">
      <h2 class="text-xl font-semibold tracking-tight mb-6">Súvisiace články</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-dashed border-gray-300 p-6 text-muted">
          <p class="text-xs font-semibold uppercase tracking-widest text-muted/70 mb-2">Newsletter · pripravujeme</p>
          <p class="font-medium text-default/70">Ďalší článok pribudne čoskoro.</p>
        </div>
        <div class="rounded-xl border border-dashed border-gray-300 p-6 text-muted">
          <p class="text-xs font-semibold uppercase tracking-widest text-muted/70 mb-2">Newsletter · pripravujeme</p>
          <p class="font-medium text-default/70">Ďalší článok pribudne čoskoro.</p>
        </div>
      </div>
    </div>

    <NewsletterCTA />
  </article>
</Layout>
