---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroRadiostanica from '~/assets/images/rk-hub-radiostanica.webp';

const metadata = {
  title: 'Bezpečnostné systémy a rádiové siete | RKS',
  description:
    'Od roku 1991 navrhujeme, staviame a servisujeme rádiové siete, systémy varovania a evakuačný rozhlas. Technológie Motorola Solutions a CALTTA.',
};

// Pas doveryhodnosti (fakty potvrdene na /certifikaty)
const dovera = [
  { big: '30+ rokov', small: 'na trhu, od roku 1991' },
  { big: '3 normy ISO', small: '9001 kvalita, 14001 životné prostredie, 45001 bezpečnosť práce' },
  { big: 'Motorola Silver', small: 'autorizovaný partner PartnerEmpower' },
  { big: 'Technická inšpekcia SR', small: 'oprávnenie na opravu aj výrobu vyhradených technických zariadení' },
];

const bezpecnostne = [
  {
    title: 'Autonómne systémy varovania (VAR-VYR)',
    desc: 'Pre ohrozovateľov podľa vyhlášky MV SR č. 388/2006 Z. z. Sirény, ovládanie, prepojenie na krízové riadenie.',
    href: '/radiokomunikacie/systemove-riesenia/autonomne-systemy-varovania',
  },
  {
    title: 'Evakuačný rozhlas a ozvučenie',
    desc: 'Certifikované systémy podľa STN EN 60849 a EN 54. Nie je to bežné ozvučenie, je to bezpečnostný systém.',
    href: '/radiokomunikacie/systemove-riesenia/evakuacny-rozhlas',
  },
];

const radioveSiete = [
  {
    title: 'Rádiové siete',
    desc: 'Od voľných frekvencií po vlastné a trunkové siete.',
    href: '/radiokomunikacie/systemove-riesenia/radiove-siete',
  },
  {
    title: 'Návrh rádiových sietí',
    desc: 'Meranie pokrytia, návrh, výpočet a projekt.',
    href: '/radiokomunikacie/sluzby/navrh-radiovych-sieti',
  },
  {
    title: 'Audit rádiových sietí',
    desc: 'Máte sieť a nefunguje, ako má? Zmeriame, kde je problém.',
    href: '/radiokomunikacie/sluzby/audit-sieti',
  },
  {
    title: 'Digitalizácia sietí',
    desc: 'Prechod z analógovej siete na digitálnu bez prerušenia prevádzky.',
    href: '/radiokomunikacie/sluzby/digitalizacia-sieti',
  },
];

const sluzby = [
  { title: 'Servis rádiostaníc', href: '/radiokomunikacie/sluzby/servis-radiostanic' },
  { title: 'Prenájom rádiostaníc', href: '/radiokomunikacie/sluzby/prenajom-radiostanic' },
  { title: 'Projekty elektrických zariadení', href: '/radiokomunikacie/sluzby/projekty-elektrickych-zariadeni' },
  { title: 'Elektroinštalačné práce', href: '/radiokomunikacie/sluzby/elektroinstalacne-prace' },
  { title: 'Základné informácie', href: '/radiokomunikacie/sluzby/zakladne-informacie' },
];

const produkty = [
  { title: 'Rádiostanice MOTOROLA (DMR)', href: 'https://mototrbo.sk' },
  { title: 'Rádiostanice CALTTA', href: '/produkty/radiostanice-caltta' },
  {
    title: 'Varovacie a vyrozumievacie systémy',
    href: '/katalog-produktov/kategoria/varovacie-a-vyrozumievacie-systemy',
  },
  { title: 'Evakuačné systémy', href: '/katalog-produktov/kategoria/evakuacne-systemy' },
  { title: 'Archív produktov', href: '/katalog-produktov/kategoria/radiostanice' },
];

const nastroje = [
  {
    title: 'RKS Chatbot',
    desc: 'Odborný poradca. Odpovie na 347 otázok o rádiových sieťach a bezpečnostných systémoch.',
    href: 'https://rks-radio-expert.vercel.app/',
  },
  { title: 'Slovník pojmov', desc: '50 odborných hesiel, od PTT po krytie IP67.', href: '/slovnik' },
  { title: 'Q&A Rádiokomunikácie', href: '/radiokomunikacie/q-a' },
  { title: 'Prípadové štúdie', href: 'https://mototrbo.sk/pripadove-studie' },
  { title: 'Newsletter „Potvrďte príjem“', href: '/radiokomunikacie/newsletter' },
];

// Referencie (mena potvrdene na /referencie, loga doplnime neskor)
const referencie = [
  'Slovenské elektrárne (EMO Mochovce, EBO Bohunice)',
  'Železnice SR',
  'SPP',
  'Národná diaľničná spoločnosť',
  'Duslo',
  'Zentiva',
  'RAJO',
  'Evonik',
  'Slovakiaring',
];

// Caste otazky. Odpovede su prevzate z existujucich stranok (/radiokomunikacie/q-a
// a /radiokomunikacie/systemove-riesenia/evakuacny-rozhlas); typograficke pomlcky
// su nahradene obycajnou interpunkciou, slova su nezmenene.
const faqs = [
  {
    q: 'Kedy sa oplatí používať profesionálne rádiostanice namiesto mobilných telefónov?',
    a: 'Všade tam, kde pracovníci potrebujú okamžitú skupinovú komunikáciu, vysokú spoľahlivosť a nezávislosť od mobilných operátorov, najmä vo výrobe, energetike, logistike, stavebníctve, bezpečnostných službách a pri správe kritickej infraštruktúry.',
  },
  {
    q: 'Aký je rozdiel medzi analógovou a digitálnou rádiovou sieťou?',
    a: 'Digitálne siete poskytujú kvalitnejší prenos hlasu, vyššiu kapacitu, šifrovanie, GPS lokalizáciu, dátové služby a jednoduchšiu správu. Analógové siete sú vhodné pre jednoduchšie aplikácie.',
  },
  {
    q: 'Musím mať povolenie na používanie profesionálnych rádiostaníc?',
    a: 'Záleží od prevádzky. Niektoré stanice pracujú na voľných frekvenciách, profesionálne siete využívajú individuálne pridelené frekvencie. RKS pomáha s výberom riešenia aj s administratívou.',
  },
  {
    q: 'Aký dosah majú profesionálne rádiostanice?',
    a: 'Závisí od výkonu, terénu, frekvencií a infraštruktúry. V otvorenom priestore niekoľko kilometrov; s retranslačnými stanicami alebo digitálnou sieťou možno pokryť celé mestá alebo rozsiahle areály.',
  },
  {
    q: 'Načo slúži evakuačný rozhlas?',
    a: 'Na zaistenie bezpečnej evakuácie pri ohrození, informuje o nutnosti opustiť objekt cez obsluhu ohlasovne požiaru alebo vopred nahovorenými správami. Slúži aj na bežné odovzdávanie informácií.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12 md:py-16">
    <!-- Hero -->
    <div class="grid items-center gap-8 lg:gap-12 lg:grid-cols-2 mb-12">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Bezpečnostné systémy a rádiové siete</h1>
        <p class="text-lg text-muted">
          Od roku 1991 navrhujeme, staviame a servisujeme rádiové siete, systémy varovania a evakuačný rozhlas. Pre
          priemysel, energetiku, dopravu a samosprávy. Dodávame technológie Motorola Solutions a CALTTA.
        </p>
      </div>
      <Image
        src={heroRadiostanica}
        alt="Profesionálna rádiostanica RKS v priemyselnom prostredí"
        widths={[400, 768, 1200, 1600]}
        sizes="(max-width: 1023px) 100vw, 50vw"
        loading="eager"
        fetchpriority="high"
        class="w-full rounded-2xl shadow-sm"
      />
    </div>

    <!-- Pas doveryhodnosti -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
      {
        dovera.map((item) => (
          <div class="rounded-xl border border-gray-200 p-5">
            <p class="text-xl font-semibold tracking-tight">{item.big}</p>
            <p class="text-base text-muted mt-1">{item.small}</p>
          </div>
        ))
      }
    </div>
    <p class="mb-16 text-sm">
      <a href="/certifikaty" class="text-primary font-medium hover:underline"
        >Pozrieť certifikáty <span aria-hidden="true">→</span></a
      >
    </p>

    <!-- Bezpecnostne systemy -->
    <h2 class="text-2xl font-semibold tracking-tight mb-2">Bezpečnostné systémy</h2>
    <p class="text-muted max-w-3xl mb-6">Varovanie, vyrozumenie a evakuácia. Tam, kde ide o ľudské životy.</p>
    <div class="grid gap-6 sm:grid-cols-2 mb-16">
      {
        bezpecnostne.map((item) => (
          <a
            href={item.href}
            class="group flex flex-col justify-between rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <div>
              <h3 class="text-xl font-semibold mb-2">{item.title}</h3>
              <p class="text-base text-muted">{item.desc}</p>
            </div>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
              Zobraziť <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <!-- Radiove siete -->
    <h2 class="text-2xl font-semibold tracking-tight mb-2">Rádiové siete</h2>
    <p class="text-muted max-w-3xl mb-6">Aby sa vaši ľudia dovolali vždy. Aj tam, kde nie je signál.</p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 mb-16">
      {
        radioveSiete.map((item) => (
          <a
            href={item.href}
            class="group flex flex-col justify-between rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <div>
              <h3 class="text-xl font-semibold mb-2">{item.title}</h3>
              <p class="text-base text-muted">{item.desc}</p>
            </div>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
              Zobraziť <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <!-- Sluzby (zoznam, bez kariet) -->
    <h2 class="text-2xl font-semibold tracking-tight mb-2">Služby</h2>
    <p class="text-muted max-w-3xl mb-6">Prevádzka, údržba a všetko, čo k tomu patrí.</p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-16">
      {
        sluzby.map((item) => (
          <a
            href={item.href}
            class="group flex items-center justify-between rounded-xl border border-gray-200 bg-white p-5 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <span class="text-lg font-medium">{item.title}</span>
            <span class="text-primary text-lg" aria-hidden="true">
              →
            </span>
          </a>
        ))
      }
    </div>

    <!-- Produkty -->
    <h2 class="text-2xl font-semibold tracking-tight mb-2">Produkty</h2>
    <p class="text-muted max-w-3xl mb-6">Čo dodávame a čo držíme na sklade.</p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-16">
      {
        produkty.map((item) => (
          <a
            href={item.href}
            class="group flex items-center justify-between rounded-xl border border-gray-200 bg-white p-5 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <span class="text-lg font-medium">{item.title}</span>
            <span class="text-primary text-lg" aria-hidden="true">
              →
            </span>
          </a>
        ))
      }
    </div>

    <!-- Nastroje a aktuality -->
    <h2 class="text-2xl font-semibold tracking-tight mb-2">Nástroje a aktuality</h2>
    <p class="text-muted max-w-3xl mb-6">Poradíme aj bez toho, aby ste museli volať.</p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-4">
      {
        nastroje.map((item) => (
          <a
            href={item.href}
            class="group flex flex-col justify-between rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <div>
              <h3 class="text-lg font-semibold mb-2">{item.title}</h3>
              {item.desc && <p class="text-base text-muted">{item.desc}</p>}
            </div>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
              Otvoriť <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
    <p class="mb-16 text-sm">
      <a href="/newsletter-odber" class="text-primary font-medium hover:underline"
        >Prihlásiť sa na odber <span aria-hidden="true">→</span></a
      >
    </p>

    <!-- Referencie -->
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Dodávali sme pre</h2>
    <div class="flex flex-wrap gap-3 mb-4">
      {
        referencie.map((name) => (
          <span class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium">{name}</span>
        ))
      }
    </div>
    <p class="mb-16 text-sm">
      <a href="/referencie" class="text-primary font-medium hover:underline"
        >Všetky referencie <span aria-hidden="true">→</span></a
      >
    </p>

    <!-- Caste otazky -->
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Časté otázky</h2>
    <div class="space-y-4 mb-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 p-5">
            <summary class="cursor-pointer list-none font-medium marker:hidden flex justify-between items-center gap-4">
              {faq.q}
              <span class="text-primary transition group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="text-muted mt-3">{faq.a}</p>
          </details>
        ))
      }
    </div>
    <p class="mb-16 text-sm">
      <a href="/radiokomunikacie/q-a" class="text-primary font-medium hover:underline"
        >Všetkých 15 otázok <span aria-hidden="true">→</span></a
      >
    </p>

    <!-- Konzultacia -->
    <div class="rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Nie ste si istí, ktoré riešenie potrebujete?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Poradíme vám a navrhneme komunikačné riešenie na mieru.</p>
      <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary inline-flex"
        >Dohodnúť nezáväznú konzultáciu</a
      >
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
