---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroRadiostanica from '~/assets/images/rk-hub-radiostanica.webp';

const metadata = {
  title: 'Rádiokomunikácie — rádiové siete a varovné systémy — RKS',
  description:
    'Komplexné rádiokomunikačné a varovné systémy od roku 1991. Návrh, projekt, realizácia a servis rádiových sietí, sirén a evakuačného rozhlasu.',
};

const systemoveRiesenia = [
  {
    title: 'Rádiové siete',
    desc: 'Profesionálna komunikácia pre firmy a organizácie — od voľných frekvencií po vlastné a trunkové siete.',
    href: '/radiokomunikacie/systemove-riesenia/radiove-siete',
  },
  {
    title: 'Autonómne systémy varovania',
    desc: 'Systémy varovania a vyrozumenia (VAR-VYR) pre ohrozovateľov podľa vyhlášky MV SR č. 388/2006 Z. z.',
    href: '/radiokomunikacie/systemove-riesenia/autonomne-systemy-varovania',
  },
  {
    title: 'Evakuačný rozhlas a ozvučenie',
    desc: 'Evakuačný rozhlas a ozvučenie objektov podľa noriem STN EN 60849 a EN 54.',
    href: '/radiokomunikacie/systemove-riesenia/evakuacny-rozhlas',
  },
];

const sluzby = [
  {
    title: 'Servis a oprava rádiostaníc',
    desc: 'Záručný aj pozáručný servis zabezpečujú školení technici a servisné skupiny s dlhoročnými skúsenosťami.',
  },
  {
    title: 'Prenájom rádiostaníc',
    desc: 'RKS je držiteľom povolenia od Úradu pre reguláciu elektronických komunikácií a poštových služieb na prenájom rádiostaníc.',
  },
  {
    title: 'Projektovanie elektrických zariadení',
    desc: 'Projektová príprava elektrických zariadení vrátane transformácie IEC noriem do projektov.',
  },
  {
    title: 'Elektroinštalačné práce',
    desc: 'Silnoprúdové aj dátové rozvody a vonkajšie rozvody — realizácia na kľúč.',
  },
];

const sluzbyLinks = [
  { title: 'Základné informácie', href: '/radiokomunikacie/sluzby/zakladne-informacie' },
  { title: 'Servis rádiostaníc', href: '/radiokomunikacie/sluzby/servis-radiostanic' },
  { title: 'Prenájom rádiostaníc', href: '/radiokomunikacie/sluzby/prenajom-radiostanic' },
  { title: 'Návrh rádiových sietí', href: '/radiokomunikacie/sluzby/navrh-radiovych-sieti' },
  { title: 'Návrh autonómnych systémov', href: '/radiokomunikacie/sluzby/navrh-autonomnych-systemov' },
  { title: 'Projekty elektrických zariadení', href: '/radiokomunikacie/sluzby/projekty-elektrickych-zariadeni' },
  { title: 'Elektroinštalačné práce', href: '/radiokomunikacie/sluzby/elektroinstalacne-prace' },
  { title: 'Digitálny systém MOTOTRBO', href: '/radiokomunikacie/sluzby/digitalny-system-mototrbo' },
  { title: 'Audit sietí', href: '/radiokomunikacie/sluzby/audit-sieti' },
  { title: 'Digitalizácia sietí', href: '/radiokomunikacie/sluzby/digitalizacia-sieti' },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12 md:py-16">
    <div class="grid items-center gap-8 lg:gap-12 lg:grid-cols-2 mb-14">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Rádiokomunikácie</h1>
        <p class="text-lg text-muted">
          Už od roku 1991 dodávame komplexné rádiokomunikačné, varovné a krízové systémy. Pre záchranné zložky,
          priemysel a samosprávy zabezpečujeme návrh, projekt, realizáciu aj servis — s technológiami značiek ako
          Motorola, Midland, Vertex či Icom.
        </p>
      </div>
      <Image
        src={heroRadiostanica}
        alt="Profesionálna rádiostanica RKS v priemyselnom prostredí"
        widths={[400, 768, 1200, 1600]}
        sizes="(max-width: 1023px) 100vw, 50vw"
        loading="eager"
        fetchpriority="high"
        class="w-full rounded-2xl shadow-sm"
      />
    </div>

    <!-- Systémové riešenia — rozcestník -->
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Systémové riešenia</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-16">
      {
        systemoveRiesenia.map((item) => (
          <a
            href={item.href}
            class="group flex flex-col justify-between rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <div>
              <h3 class="text-lg font-semibold mb-2">{item.title}</h3>
              <p class="text-sm text-muted">{item.desc}</p>
            </div>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
              Zobraziť <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <!-- Služby zákazníkom -->
    <h2 class="text-2xl font-semibold tracking-tight mb-2">Služby zákazníkom</h2>
    <p class="text-muted max-w-3xl mb-6">
      Okrem systémových riešení poskytujeme celý rad odborných služieb pre prevádzku a údržbu rádiokomunikačnej
      techniky.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 mb-8">
      {
        sluzby.map((item) => (
          <div class="rounded-xl border border-gray-200 p-6">
            <h3 class="text-lg font-semibold mb-2">{item.title}</h3>
            <p class="text-sm text-muted">{item.desc}</p>
          </div>
        ))
      }
    </div>

    <div class="rounded-xl border border-gray-200 p-6 mb-16">
      <h3 class="text-base font-semibold mb-4">Všetky služby</h3>
      <ul class="grid gap-x-8 gap-y-2 sm:grid-cols-2 lg:grid-cols-3 text-sm">
        {
          sluzbyLinks.map((item) => (
            <li>
              <a href={item.href} class="text-muted hover:text-primary hover:underline">
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>
      <p class="mt-5 text-sm">
        <a href="/radiokomunikacie/produkty/mototrbo" class="text-primary font-medium hover:underline">
          Produkty: digitálny systém Mototrbo →
        </a>
      </p>
    </div>

    <div class="rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Nie ste si istí, ktoré riešenie potrebujete?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Poradíme vám a navrhneme komunikačné riešenie na mieru.</p>
      <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary inline-flex"
        >Dohodnúť nezáväznú konzultáciu</a
      >
    </div>
  </section>
</Layout>
