---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import heroEvakuacia from '~/assets/images/radiokomunikacie/evacuation-5.webp';

const metadata = {
  title: 'Evakuačný rozhlas a ozvučenie objektov — RKS',
  description:
    'Návrh a dodávka evakuačného rozhlasu a ozvučenia podľa noriem STN EN 60849 a EN 54. Pre haly, hotely, stanice, školy a verejné objekty. S automatickou kontrolou zvukového reťazca.',
};

const faqs = [
  {
    q: 'Načo slúži evakuačný rozhlas?',
    a: 'Na zaistenie bezpečnej evakuácie pri ohrození — informuje o nutnosti opustiť objekt cez obsluhu ohlasovne požiaru alebo vopred nahovorenými správami. Slúži aj na bežné odovzdávanie informácií.',
  },
  {
    q: 'Aké normy musí spĺňať?',
    a: 'Podľa STN EN 60849 musí spĺňať celú škálu požiadaviek; všetky komponenty zároveň normu EN 54.',
  },
  {
    q: 'Prečo nestačí bežné ozvučenie?',
    a: 'Pri modulárnych systémoch možno zostaviť ústredňu, ktorá normu spĺňa, aj takú, ktorá nie. Kľúčové je zvoliť certifikovaný systém a správnu konfiguráciu.',
  },
  {
    q: 'Čo znamená automatická kontrola zvukového reťazca?',
    a: 'Ústredňa trvale kontroluje celú cestu signálu — riadiacu jednotku, mikrofóny aj s káblami, zosilňovače, 100 V rozvody — a poruchy hlási; pri výpadku zapojí záložný zosilňovač.',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/radiokomunikacie">← Rádiokomunikácie</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Evakuačný rozhlas a ozvučenie objektov</h1>

    <div class="grid items-center gap-8 lg:gap-10 lg:grid-cols-5 mb-12">
      <p class="text-lg text-muted lg:col-span-3">
        Pri evakuácii rozsiahleho objektu musí byť hlasový pokyn počuteľný a zrozumiteľný za každých okolností — od toho
        závisia životy. Navrhneme a dodáme evakuačný rozhlas spĺňajúci normy STN EN 60849 a EN 54, ktorý za každých
        okolností splní svoju funkciu pri ochrane osôb.
      </p>
      <div class="lg:col-span-2 aspect-[4/3] overflow-hidden rounded-2xl shadow-sm">
        <Image
          src={heroEvakuacia}
          alt="Evakuácia objektu a rádiová komunikácia personálu"
          widths={[400, 600, 768]}
          sizes="(max-width: 1023px) 100vw, 40vw"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="prose prose-lg max-w-none">
      <h2>Na čo slúži evakuačný rozhlas</h2>
      <p>
        Evakuačný rozhlas informuje užívateľov a návštevníkov o nutnosti opustiť objekt pri ohrození. Informovanie
        vykoná obsluha ohlasovne požiaru, prípadne sa prehrajú vopred nahovorené poplachové správy. Mimo požiarneho
        ohrozenia slúži aj na bežné odovzdávanie informácií. Týka sa hotelov, letiskových hál, vlakových a autobusových
        staníc, výrobných hál, škôl, nemocníc či systémov civilnej obrany.
      </p>

      <h2>Normy STN EN 60849 a EN 54</h2>
      <p>
        Rozhlasové systémy na evakuáciu osôb musia podľa normy <strong>STN EN 60849 — Núdzové zvukové systémy</strong>
        spĺňať celú škálu požiadaviek, ktoré zabezpečia, že systém bude za všetkých okolností pripravený plniť svoju
        funkciu. Všetky komponenty zároveň musia spĺňať požiadavky normy <strong>EN 54</strong>.
      </p>
      <p>
        Keďže väčšina systémov má modulárnu koncepciu, z rovnakých komponentov možno zostaviť ústredňu, ktorá normu
        spĺňa, aj takú, ktorá ju nespĺňa. Pri návrhu je preto kľúčové zvoliť certifikovaný systém a zabezpečiť, aby
        konfigurácia ústredne spĺňala všetky aplikovateľné požiadavky normy.
      </p>

      <h2>Automatická kontrola zvukového reťazca</h2>
      <p>
        Ústredňa musí trvale kontrolovať bezporuchovú funkciu celej cesty zvukového signálu aj vlastných riadiacich
        obvodov:
      </p>
      <ul>
        <li>kontrola riadiacej jednotky ústredne s chybovým hlásením,</li>
        <li>kontrola mikrofónnych staníc vrátane vložky a kábla,</li>
        <li>kontrola výkonových zosilňovačov a prepojovacích káblov,</li>
        <li>automatické zapojenie záložného zosilňovača pri výpadku prevádzkového,</li>
        <li>kontrola 100 V rozvodov s chybovým hlásením,</li>
        <li>protokolovanie neštandardných stavov v pamäti,</li>
        <li>generátor výstražných signálov s adresovaním do zón,</li>
        <li>jednotka digitálneho záznamu hlásenia pod automatickou kontrolou.</li>
      </ul>
    </div>

    <h2 class="text-2xl font-semibold tracking-tight mt-14 mb-6">Časté otázky</h2>
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 p-5">
            <summary class="cursor-pointer list-none font-medium marker:hidden flex justify-between items-center gap-4">
              {faq.q}
              <span class="text-primary transition group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="text-muted mt-3">{faq.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Plánujete evakuačný rozhlas alebo ozvučenie?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">Navrhneme systém spĺňajúci normy STN EN 60849 a EN 54 pre váš objekt.</p>
      <a href="/lp/konzultacia.html?utm_source=web&amp;utm_campaign=web" class="btn-primary inline-flex">Dohodnúť nezáväznú konzultáciu</a>
    </div>
  </section>
</Layout>
