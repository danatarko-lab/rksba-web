---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Referencie | RKS',
  description:
    'Vybrané referencie RKS: autonómne systémy varovania, rádiové siete a evakuačný rozhlas pre jadrové elektrárne, železnice, plynárenstvo, chemický a potravinársky priemysel.',
};

const SE = '/images/referencie/slovenske-elektrarne.png';
const ZSR = '/images/referencie/zsr.svg';

const sections = [
  {
    title: 'Autonómne systémy varovania',
    clients: [
      { name: 'Duslo (o. z. ISTROCHEM, Bratislava)', logo: '/images/referencie/duslo.svg' },
      { name: 'Distribučné centrum Tesco Beckov', logo: '/images/referencie/tesco.svg' },
      { name: 'Fortischem (Nováky)', logo: '/images/referencie/fortischem.png' },
      { name: 'Slovenské elektrárne (závod Elektrárne Nováky)', logo: SE },
      { name: 'Slovenské elektrárne (OZ EMO Mochovce)', logo: SE },
      { name: 'MEGGLE Slovakia, pôvodne RAJO (Bratislava)', logo: '/images/referencie/rajo.png' },
      { name: 'Evonik Fermas (Slovenská Ľupča)', logo: '/images/referencie/evonik-fermas.svg' },
      { name: 'Brenntag (Slovenská Ľupča)', logo: '/images/referencie/brenntag.svg' },
      { name: 'Flaga (Bánovce nad Bebravou)', logo: '/images/referencie/flaga.svg' },
      { name: 'Levmilk (Levice)', logo: '/images/referencie/levmilk.svg' },
      { name: 'Zimný štadión Levice', logo: '/images/referencie/ssz-levice.png' },
      { name: 'Zimný štadión Nové Mesto nad Váhom (TSM)', logo: '/images/referencie/tsm-nove-mesto.png' },
      { name: 'SVAMAN (Myjava)', logo: '/images/referencie/swaman.png' },
      { name: 'Zentiva (Hlohovec)', logo: '/images/referencie/zentiva.svg' },
      { name: 'VINICA GASTRA (Vinica)', logo: '/images/referencie/vinica.jpg' },
    ],
  },
  {
    title: 'Rádiové siete',
    clients: [
      { name: 'Slovenské elektrárne (OZ EMO Mochovce)', logo: SE },
      { name: 'Slovenské elektrárne (OZ EBO Jaslovské Bohunice)', logo: SE },
      { name: 'ŽSR Trnava Kúty', logo: ZSR },
      { name: 'ŽSR Podunajské Biskupice Komárno', logo: ZSR },
      { name: 'SPP (Bratislava)', logo: '/images/referencie/spp.png' },
      { name: 'Slovakiaring (Orechová Potôň)', logo: '/images/referencie/slovakiaring.svg' },
      { name: 'NDS (Bratislava)', logo: '/images/referencie/nds.png' },
      { name: 'Mestská polícia Žilina', logo: '/images/referencie/mestska-policia-zilina.png' },
      { name: 'Vodárenská nádrž Turček (SVP)', logo: '/images/referencie/svp.png' },
      { name: 'OSCR Oščadnica' },
    ],
  },
  {
    title: 'Evakuačný rozhlas',
    clients: [{ name: 'Goldbeck (Bratislava)', logo: '/images/referencie/goldbeck.png' }],
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/">← Domov</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Referencie</h1>

    <p class="text-lg text-muted max-w-3xl mb-12">
      Za viac ako 30 rokov sme realizovali stovky projektov. Medzi najvýznamnejšie patria:
    </p>

    <div class="space-y-14">
      {
        sections.map((section) => (
          <div>
            <h2 class="text-2xl font-semibold tracking-tight mb-6">{section.title}</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {section.clients.map((client) => (
                <li class="flex items-center gap-4 rounded-xl border border-gray-200 p-4">
                  {client.logo ? (
                    <img
                      src={client.logo}
                      alt={client.name}
                      loading="lazy"
                      class="h-14 w-24 flex-none object-contain"
                    />
                  ) : (
                    <span
                      class="flex h-14 w-24 flex-none items-center justify-center rounded-md border border-dashed border-gray-300 bg-gray-50 text-[10px] uppercase tracking-wider text-muted"
                      aria-hidden="true"
                    >
                      Logo
                    </span>
                  )}
                  <span class="text-sm font-medium">{client.name}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Chcete sa stať našou ďalšou referenciou?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">
        Navrhneme a zrealizujeme riešenie na mieru pre váš objekt alebo prevádzku.
      </p>
      <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary inline-flex"
        >Dohodnúť nezáväznú konzultáciu</a
      >
    </div>
  </section>
</Layout>
