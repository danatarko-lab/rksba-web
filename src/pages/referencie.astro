---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Referencie | RKS',
  description:
    'Vybrané referencie RKS: autonómne systémy varovania, rádiové siete a evakuačný rozhlas pre jadrové elektrárne, železnice, plynárenstvo, chemický a potravinársky priemysel.',
};

const sections = [
  {
    title: 'Autonómne systémy varovania',
    clients: [
      'Duslo (o. z. ISTROCHEM, Bratislava)',
      'Distribučné centrum Tesco Beckov',
      'Novácke chemické závody (Nováky)',
      'Slovenské elektrárne (závod Elektrárne Nováky)',
      'Slovenské elektrárne (OZ EMO Mochovce)',
      'RAJO (Bratislava)',
      'Evonik Fermas (Slovenská Ľupča)',
      'Brenntag (Slovenská Ľupča)',
      'Flaga (Bánovce nad Bebravou)',
      'Levmilk (Levice)',
      'Zimný štadión Levice',
      'Zimný štadión Nové Mesto nad Váhom',
      'Swaman (Myjava)',
      'Zentiva (Hlohovec)',
      'VINICA GASTRA (Vinica)',
    ],
  },
  {
    title: 'Rádiové siete',
    clients: [
      'Slovenské elektrárne (OZ EMO Mochovce)',
      'Slovenské elektrárne (OZ EBO Jaslovské Bohunice)',
      'ŽSR Trnava Kúty',
      'ŽSR Podunajské Biskupice Komárno',
      'SPP (Bratislava)',
      'Slovakiaring (Orechová Potôň)',
      'NDS (Bratislava)',
      'VD Turček',
      'OSCR Oščadnica',
    ],
  },
  {
    title: 'Evakuačný rozhlas',
    clients: ['Goldback (Bratislava)'],
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/">← Domov</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Referencie</h1>

    <p class="text-lg text-muted max-w-3xl mb-12">
      Za viac ako 30 rokov sme realizovali stovky projektov. Medzi najvýznamnejšie patria:
    </p>

    <div class="space-y-14">
      {
        sections.map((section) => (
          <div>
            <h2 class="text-2xl font-semibold tracking-tight mb-6">{section.title}</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {section.clients.map((client) => (
                <li class="flex items-center gap-4 rounded-xl border border-gray-200 p-4">
                  <span
                    class="flex h-12 w-16 flex-none items-center justify-center rounded-md border border-dashed border-gray-300 bg-gray-50 text-[10px] uppercase tracking-wider text-muted"
                    aria-hidden="true"
                  >
                    Logo
                  </span>
                  <span class="text-sm font-medium">{client}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-primary/5 border border-primary/20 p-8 text-center">
      <h2 class="text-xl md:text-2xl font-semibold mb-3">Chcete sa stať našou ďalšou referenciou?</h2>
      <p class="text-muted mb-6 max-w-xl mx-auto">
        Navrhneme a zrealizujeme riešenie na mieru pre váš objekt alebo prevádzku.
      </p>
      <a href="/lp/konzultacia.html?utm_source=web&amp;utm_campaign=web" class="btn-primary inline-flex">Dohodnúť nezáväznú konzultáciu</a>
    </div>
  </section>
</Layout>
