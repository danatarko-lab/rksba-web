---
import Layout from '~/layouts/PageLayout.astro';
import NewsletterCTA from '~/components/widgets/NewsletterCTA.astro';

const metadata = { title: 'Aktuality | RKS' };

const cards = [
  { title: 'Rádiové komunikácie', href: '/aktuality/radiokomunikacie' },
  { title: 'Energetika', href: '/aktuality/energetika' },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 sm:px-6 pt-12 md:pt-20 pb-16 md:pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {
        cards.map((card) => (
          <a
            href={card.href}
            class="group flex aspect-square flex-col items-center justify-center rounded-xl border border-gray-200 bg-white p-8 text-center transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-4">{card.title}</h2>
            <span class="inline-flex items-center gap-1 font-medium text-primary group-hover:underline">
              Vstúpiť <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <NewsletterCTA />
  </section>
</Layout>
