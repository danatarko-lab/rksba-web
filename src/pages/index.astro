---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'RKS — energetické riešenia a rádiokomunikácie pre firmy',
  ignoreTitleTemplate: true,
};

const cards = [
  {
    title: 'Rádiokomunikácie',
    description: 'Rádiové siete, varovné systémy, Mototrbo. Pre záchranné zložky, samosprávy, priemysel.',
    cta: 'Vstúpiť',
    href: '/radiokomunikacie',
  },
  {
    title: 'Energetika',
    description: 'EMS, fotovoltika, batérie, EV nabíjačky, smart building. Pre B2B firmy a komerčné budovy.',
    cta: 'Vstúpiť',
    href: '/energetika',
  },
  {
    title: 'Aktuality',
    description: 'Newslettre, blogy, časté otázky a prípadové štúdie.',
    cta: 'Otvoriť',
    href: '/aktuality',
  },
  {
    title: 'Kontakt',
    description: '+421 903 277 654\nrks@rksba.sk\nVajnorská 6A, Ivanka pri Dunaji',
    cta: 'Kontaktovať',
    href: '/kontakt',
  },
];

const why = [
  { title: '30+ rokov skúseností (od 1991)', icon: 'tabler:award' },
  { title: 'Silní technologickí partneri', icon: 'tabler:building-skyscraper' },
  { title: 'Projekt + realizácia + servis pod jednou strechou', icon: 'tabler:home' },
  {
    title: 'Certifikovaná kvalita a oprávnenia',
    text: 'Systém manažérstva ISO 9001, 14001 a 45001. Oprávnenie Technickej inšpekcie SR na opravu a výrobu vyhradených elektrických zariadení do 1000 V.',
    icon: 'tabler:certificate',
  },
];
---

<Layout metadata={metadata}>
  <!-- SEKCIA 1 — HERO (video pozadie) -->
  <section class="relative isolate overflow-hidden">
    <!-- video pozadie -->
    <video
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/videos/rks-hero-poster-opt.jpg"
      aria-hidden="true"
      tabindex="-1"
    >
      <source src="/videos/rks-hero.mp4" type="video/mp4" />
    </video>
    <!-- tmavý overlay pre čitateľnosť bieleho textu -->
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-black/55 via-black/45 to-black/65"></div>

    <div class="mx-auto max-w-5xl px-4 sm:px-6 py-24 md:py-36 text-center">
      <p class="text-sm font-medium uppercase tracking-wider text-white/90 mb-3">
        Slovenská technologická firma od 1991
      </p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-balance text-white drop-shadow-lg">
        30 rokov technológií pre slovenský B2B trh
      </h1>
      <div class="mt-8">
        <a href="/lp/konzultacia.html?utm_source=web&amp;utm_campaign=web" class="btn-primary inline-flex">Dohodnúť nezáväznú konzultáciu</a>
      </div>
    </div>
  </section>

  <!-- SEKCIA 2 — 4 ŠTVORCOVÉ KARTY -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 pb-12 md:pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        cards.map((card) => (
          <a
            href={card.href}
            class="group flex aspect-square flex-col justify-between rounded-xl border border-gray-200 bg-white p-8 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <div>
              <h2 class="text-2xl font-medium tracking-tight mb-3">{card.title}</h2>
              <p class="text-base text-muted whitespace-pre-line">{card.description}</p>
            </div>
            <span class="mt-6 inline-flex items-center gap-1 font-medium text-primary group-hover:underline">
              {card.cta} <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- SEKCIA 3 — PREČO RKS -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-16 md:pb-24">
    <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-center mb-10">Prečo RKS</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        why.map((item) => (
          <div class="flex flex-col items-center text-center">
            <Icon name={item.icon} class="w-8 h-8 text-primary mb-3" />
            <p class="text-base font-medium">{item.title}</p>
            {item.text && <p class="text-sm text-muted mt-1">{item.text}</p>}
          </div>
        ))
      }
    </div>
  </section>
</Layout>
