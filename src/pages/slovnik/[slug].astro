---
import fs from 'node:fs';
import Layout from '~/layouts/PageLayout.astro';

type Term = { id: number; slug: string; pojem: string; kategoria: string; definicia: string };

const allTerms: Term[] = JSON.parse(fs.readFileSync('_materials/slovnik/slovnik.json', 'utf-8'));

export async function getStaticPaths() {
  const terms: Term[] = JSON.parse(fs.readFileSync('_materials/slovnik/slovnik.json', 'utf-8'));
  return terms.map((t) => ({ params: { slug: t.slug }, props: { term: t } }));
}

const { term } = Astro.props as { term: Term };

const firstSentence = (def: string) => {
  const m = def.match(/^(.*?[.!?])(\s|$)/);
  return (m ? m[1] : def).trim();
};

const siteUrl = (Astro.site?.toString() || 'https://rksba.sk/').replace(/\/$/, '');
const pageUrl = `${siteUrl}/slovnik/${term.slug}`;

const metadata = {
  title: `${term.pojem} | Slovník pojmov | RKS`,
  description: firstSentence(term.definicia),
};

// schema.org DefinedTerm: presne to, čo AI asistenti a vyhľadávače citujú.
const termSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: term.pojem,
  description: term.definicia,
  termCode: term.slug,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'Slovník rádiokomunikačných pojmov RKS',
    url: `${siteUrl}/slovnik`,
  },
  url: pageUrl,
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-2xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-6"><a class="hover:underline" href="/slovnik">← Slovník pojmov</a></p>

    <p class="text-sm font-medium uppercase tracking-wider text-primary mb-2">{term.kategoria}</p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-5">{term.pojem}</h1>

    <div class="prose prose-lg max-w-none">
      <p>{term.definicia}</p>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:items-center">
      <a class="btn-primary inline-flex" href="/lp/konzultacia.html?utm_source=web&utm_medium=slovnik&utm_campaign=web"
        >Dohodnúť nezáväznú konzultáciu</a
      >
      <a class="text-primary hover:underline" href="/slovnik">Späť na slovník pojmov</a>
    </div>

    <p class="mt-12 pt-6 border-t border-gray-200 text-sm text-muted">
      Pojem je súčasťou slovníka RKS. Celkovo {allTerms.length} hesiel z oblasti rádiokomunikácií.
    </p>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(termSchema)} />
</Layout>
