---
import Layout from '~/layouts/PageLayout.astro';

const metadata = { title: 'Kontakt | RKS' };
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-10">Kontakt</h1>

    <div class="grid gap-10 md:grid-cols-2">
      <!-- Sídlo / fakturačná adresa -->
      <div>
        <h2 class="text-xl font-medium mb-3">Sídlo / fakturačná adresa</h2>
        <address class="not-italic text-muted leading-relaxed">
          R K S, spol s r.o.<br />
          Rajecká 36<br />
          821 07 Bratislava<br />
          Slovensko
        </address>

        <dl class="mt-5 text-sm text-muted space-y-1">
          <div><dt class="inline font-medium text-default">IČO:</dt> <dd class="inline">30841275</dd></div>
          <div><dt class="inline font-medium text-default">DIČ:</dt> <dd class="inline">2020328398</dd></div>
          <div><dt class="inline font-medium text-default">IČ DPH:</dt> <dd class="inline">SK2020328398</dd></div>
          <div>
            <dt class="inline font-medium text-default">OR:</dt>
            <dd class="inline">Obchodný register Mestského súdu Bratislava III</dd>
          </div>
        </dl>

        <h3 class="text-base font-medium mt-6 mb-2">Bankové spojenie</h3>
        <p class="text-sm text-muted leading-relaxed">
          Tatra banka, a.s.<br />
          IBAN: SK17 1100 0000 0026 2802 1295<br />
          BIC: TATRSKBXXXX
        </p>
      </div>

      <!-- Prevádzka + kontakty -->
      <div>
        <h2 class="text-xl font-medium mb-3">Adresa prevádzky</h2>
        <address class="not-italic text-muted leading-relaxed">
          R K S, spol s r.o.<br />
          Vajnorská 6A<br />
          900 28 Ivanka pri Dunaji
        </address>
        <p class="text-sm text-muted mt-1">GPS: 48.1915, 17.2493</p>

        <h3 class="text-base font-medium mt-6 mb-2">Kontakty</h3>
        <ul class="text-muted space-y-1">
          <li><a class="hover:text-primary hover:underline" href="tel:+421903717634">+421 903 717 634</a></li>
          <li><a class="hover:text-primary hover:underline" href="tel:+421245648204">+421 2 4564 8204</a></li>
          <li><a class="hover:text-primary hover:underline" href="tel:+421245648205">+421 2 4564 8205</a></li>
          <li><a class="hover:text-primary hover:underline" href="mailto:rks@rksba.sk">rks@rksba.sk</a></li>
        </ul>
        <p class="text-sm text-muted mt-3">Prevádzkové hodiny: Po az Pi: 08:00 do 16:30</p>

        <a href="/lp/konzultacia.html?utm_source=web&utm_campaign=web" class="btn-primary text-sm mt-8 inline-flex"
          >Dohodnúť nezáväznú konzultáciu</a
        >
      </div>
    </div>
  </section>
</Layout>
