---
import Layout from '~/layouts/PageLayout.astro';

const metadata = { title: 'Aktuality — Energetika — RKS' };

const tabs = [
  { label: 'Energy Memo', href: '/energetika/blog' },
  { label: 'Q&A', href: '/energetika/q-a' },
];

const cards = [
  {
    title: 'Energy Memo — Energetika',
    desc: 'Odborné články o energetike pre firmy.',
    href: '/energetika/blog',
  },
  {
    title: 'Q&A — Energetika',
    desc: 'Časté otázky k FVE, BESS, EMS a smart building.',
    href: '/energetika/q-a',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/aktuality">← Aktuality</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-8">Energetika</h1>

    <div class="flex flex-wrap gap-6 border-b border-gray-200 mb-8">
      {
        tabs.map((tab) => (
          <a
            href={tab.href}
            class="-mb-px inline-flex items-center gap-1 border-b-2 border-transparent pb-3 text-base font-medium text-muted transition hover:text-gray-700"
          >
            {tab.label}
          </a>
        ))
      }
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      {
        cards.map((card) => (
          <a
            href={card.href}
            class="group block rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <h2 class="text-lg font-medium mb-1">{card.title}</h2>
            <p class="text-sm text-muted mb-4">{card.desc}</p>
            <span class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
              Otvoriť <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
