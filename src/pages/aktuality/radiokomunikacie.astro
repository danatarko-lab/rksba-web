---
import Layout from '~/layouts/PageLayout.astro';
import NewsletterCTA from '~/components/widgets/NewsletterCTA.astro';

const metadata = { title: 'Aktuality: bezpečnostné systémy a rádiové siete | RKS' };

const tabs = [
  { label: 'Newsletter', href: '/radiokomunikacie/newsletter' },
  { label: 'Q&A', href: '/radiokomunikacie/q-a' },
  { label: 'RKS Chatbot', href: 'https://rks-radio-expert.vercel.app/', external: true },
  { label: 'Prípadové štúdie', href: 'https://mototrbo.sk/pripadove-studie', external: true },
];

const cards = [
  {
    title: '„Potvrďte príjem" (Newsletter)',
    desc: 'Pravidelný newsletter pre rádiokomunikácie.',
    href: '/radiokomunikacie/newsletter',
  },
  {
    title: 'Q&A: rádiokomunikácie',
    desc: 'Časté otázky k rádiovým sieťam a varovným systémom.',
    href: '/radiokomunikacie/q-a',
  },
  {
    title: 'RKS Chatbot',
    desc: 'Interaktívny AI asistent, opýtajte sa na rádiokomunikácie.',
    href: 'https://rks-radio-expert.vercel.app/',
    external: true,
  },
  {
    title: 'Prípadové štúdie',
    desc: 'Realizované projekty v rádiokomunikáciách.',
    href: 'https://mototrbo.sk/pripadove-studie',
    external: true,
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/aktuality">← Aktuality</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-8">Rádiové komunikácie</h1>

    <div class="flex flex-wrap gap-6 border-b border-gray-200 mb-8">
      {
        tabs.map((tab) => (
          <a
            href={tab.href}
            target={tab.external ? '_blank' : undefined}
            rel={tab.external ? 'noopener noreferrer' : undefined}
            class="-mb-px inline-flex items-center gap-1 border-b-2 border-transparent pb-3 text-base font-medium text-muted transition hover:text-gray-700"
          >
            {tab.label}
            {tab.external && <span aria-hidden="true">↗</span>}
          </a>
        ))
      }
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      {
        cards.map((card) => (
          <a
            href={card.href}
            target={card.external ? '_blank' : undefined}
            rel={card.external ? 'noopener noreferrer' : undefined}
            class="group block rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <h2 class="text-lg font-medium mb-1 inline-flex items-center gap-1">
              {card.title}
              {card.external && <span aria-hidden="true">↗</span>}
            </h2>
            <p class="text-sm text-muted mb-4">{card.desc}</p>
            <span class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
              Otvoriť <span aria-hidden="true">{card.external ? '↗' : '→'}</span>
            </span>
          </a>
        ))
      }
    </div>

    <NewsletterCTA />
  </section>
</Layout>
