---
import Layout from '~/layouts/PageLayout.astro';

const metadata = { title: 'Aktuality — Rádiové komunikácie — RKS' };

const tabs = [
  {
    id: 'newsletter',
    label: 'Newsletter',
    card: { title: '„Potvrďte príjem" (Newsletter)', desc: 'Pravidelný newsletter pre rádiokomunikácie.', href: '/radiokomunikacie/newsletter' },
  },
  {
    id: 'qa',
    label: 'Q&A',
    card: { title: 'Q&A — Rádiokomunikácie', desc: 'Časté otázky k rádiovým sieťam a varovným systémom.', href: '/radiokomunikacie/q-a' },
  },
  {
    id: 'pripadove-studie',
    label: 'Prípadové štúdie',
    card: { title: 'Prípadové štúdie — Rádiokomunikácie', desc: 'Realizované projekty v rádiokomunikáciách.', href: '/radiokomunikacie/pripadove-studie' },
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12 md:py-16">
    <p class="text-sm text-muted mb-2"><a class="hover:underline" href="/aktuality">← Aktuality</a></p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-8">Rádiové komunikácie</h1>

    <div class="flex flex-wrap gap-6 border-b border-gray-200 mb-8" role="tablist">
      {
        tabs.map((tab, i) => (
          <button
            type="button"
            role="tab"
            data-tab={tab.id}
            class:list={[
              'aktuality-tab -mb-px border-b-2 pb-3 text-base font-medium transition',
              i === 0 ? 'border-primary text-primary' : 'border-transparent text-muted hover:text-gray-700',
            ]}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    {
      tabs.map((tab, i) => (
        <div data-panel={tab.id} class:list={['aktuality-panel', { hidden: i !== 0 }]}>
          <a
            href={tab.card.href}
            class="group block max-w-md rounded-xl border border-gray-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-primary hover:shadow-lg"
          >
            <h2 class="text-lg font-medium mb-1">{tab.card.title}</h2>
            <p class="text-sm text-muted mb-4">{tab.card.desc}</p>
            <span class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
              Otvoriť <span aria-hidden="true">→</span>
            </span>
          </a>
        </div>
      ))
    }
  </section>
</Layout>

<script>
  document.querySelectorAll('.aktuality-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-tab');
      document.querySelectorAll('.aktuality-tab').forEach((b) => {
        const active = b === btn;
        b.classList.toggle('border-primary', active);
        b.classList.toggle('text-primary', active);
        b.classList.toggle('border-transparent', !active);
        b.classList.toggle('text-muted', !active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll('.aktuality-panel').forEach((panel) => {
        panel.classList.toggle('hidden', panel.getAttribute('data-panel') !== id);
      });
    });
  });
</script>
