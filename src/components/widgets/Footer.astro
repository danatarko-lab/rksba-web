---
import { getHomePermalink } from '~/utils/permalinks';

interface ContactItem {
  text: string;
  href?: string;
}

export interface Props {
  tagline?: string;
  contact?: {
    phone?: ContactItem;
    email?: ContactItem;
    address?: string;
    hours?: string;
  };
  cta?: { text: string; href: string };
  copyright?: string;
  legal?: string;
  bottomLinks?: Array<{ text: string; href: string }>;
}

const { tagline = '', contact = {}, cta, copyright = '', legal = '', bottomLinks = [] } = Astro.props;
---

<footer class="bg-[#0b1b3a] text-white not-prose">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid gap-10 md:grid-cols-3 md:gap-8">
      <!-- Vlavo: logo + tagline -->
      <div>
        <a href={getHomePermalink()} class="inline-block text-2xl font-bold tracking-tight text-white">RKS</a>
        {tagline && <p class="mt-4 max-w-xs text-sm text-white/70">{tagline}</p>}
      </div>

      <!-- V strede: kontakt -->
      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-white">Kontakt</p>
        <ul class="space-y-2 text-sm text-white/80">
          {
            contact.phone && (
              <li>
                <a class="hover:underline" href={contact.phone.href}>
                  {contact.phone.text}
                </a>
              </li>
            )
          }
          {
            contact.email && (
              <li>
                <a class="hover:underline" href={contact.email.href}>
                  {contact.email.text}
                </a>
              </li>
            )
          }
          {contact.address && <li>{contact.address}</li>}
          {contact.hours && <li>{contact.hours}</li>}
        </ul>
      </div>

      <!-- Vpravo: konzultacia -->
      <div class="md:text-right">
        {
          cta && (
            <a href={cta.href} class="btn-primary inline-flex">
              {cta.text}
            </a>
          )
        }
      </div>
    </div>

    <!-- Spodny pasik -->
    <div class="mt-10 border-t border-white/15 pt-6">
      {legal && <p class="text-xs text-white/50">{legal}</p>}
      <p class="mt-2 text-sm text-white/70">
        {copyright}
        {
          bottomLinks.map((link) => (
            <Fragment>
              {' · '}
              <a class="text-white hover:underline" href={link.href}>
                {link.text}
              </a>
            </Fragment>
          ))
        }
      </p>
    </div>
  </div>
</footer>
